    map['level'] = Variable<int>(level);
    map['sentences_heritage'] = Variable<String>(sentencesHeritage);
    map['sentences_general'] = Variable<String>(sentencesGeneral);
    map['initial_difficulty'] = Variable<double>(initialDifficulty);
    return map;
