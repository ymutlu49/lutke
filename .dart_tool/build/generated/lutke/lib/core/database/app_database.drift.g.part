          ? const Value.absent()
          : Value(english),
      audioUrl: audioUrl == null && nullToAbsent
          ? const Value.absent()
          : Value(audioUrl),
      gender: Value(gender),
      category: Value(category),
      level: Value(level),
      sentencesHeritage: Value(sentencesHeritage),
      sentencesGeneral: Value(sentencesGeneral),
      initialDifficulty: Value(initialDifficulty),
